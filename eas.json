{
  "cli": {
    "version": ">= 3.13.1",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mechtrix.onrender.com/api"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mechtrix.onrender.com/api"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
